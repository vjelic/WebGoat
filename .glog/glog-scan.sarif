            "text": "HTTP Endpoint Exposes Sensitive PII In Response"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/main/java/org/owasp/webgoat/lessons/clientsidefiltering/Salaries.java",
